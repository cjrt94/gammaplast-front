# Envío de formularios (Resend) — variables SOLO de servidor.
# Copia este archivo a .env y rellena los valores.
#
# NOTA: el prefijo NUXT_ es obligatorio — así Nuxt las inyecta en runtimeConfig en runtime
# (nombre de env NUXT_RESEND_API_KEY → runtimeConfig.resendApiKey). En Vercel se configuran igual.

# API key de Resend (https://resend.com/api-keys).
NUXT_RESEND_API_KEY=

# Remitente. DEBE ser un dominio verificado en Resend (ej. "Gamma Plast <no-reply@gammaplast.com.pe>").
# Si se deja vacío, cae a onboarding@resend.dev (solo entrega a la cuenta dueña de la API key — dev).
NUXT_MAIL_FROM=

# Destinatarios (coma-separados). Si se dejan vacíos, usan los valores por defecto del nuxt.config.
NUXT_CONTACT_TO=comercial@gammaplast.com.pe, comercial2@gammaplast.com.pe
NUXT_CAREERS_TO=recursoshumanos@gammaplast.com.pe


# ─────────────────────────────────────────────────────────────────────────────
# Firebase — back office (CMS + leads). Ver plan y agents/bobby.
#
# Web SDK (público, va al bundle cliente — NO son secretas). Firebase console →
# Project settings → Tus apps → Web → configuración del SDK.
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_APP_ID=

# Admin SDK (SOLO servidor — SECRETO). Firebase console → Project settings →
# Cuentas de servicio → Generar nueva clave privada (descarga un JSON).
# Guarda el JSON COMPLETO en base64 en una sola variable:
#   macOS:  base64 -i serviceAccount.json | pbcopy
# y pega el resultado aquí. (base64 evita que el PEM multilínea se rompa en Vercel.)
NUXT_FIREBASE_SERVICE_ACCOUNT=
# Bucket de Storage (mismo valor que NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET, ej. gammaplast.appspot.com).
NUXT_FIREBASE_STORAGE_BUCKET=
